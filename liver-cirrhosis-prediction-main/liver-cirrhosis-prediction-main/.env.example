# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://liver_user:secure_password@localhost:5432/liver_cirrhosis_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=liver_user
DATABASE_PASSWORD=secure_password
DATABASE_NAME=liver_cirrhosis_db

# JWT & Authentication
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# LLM API Keys (Optional)
OPENAI_API_KEY=sk-your-openai-key-here
GROQ_API_KEY=your-groq-key-here

# Application Settings
APP_ENV=development  # production or development
DEBUG=True
LOG_LEVEL=INFO

# Redis Cache (Optional)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# AWS Configuration (For S3 storage - Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=liver-cirrhosis-reports
AWS_REGION=us-east-1

# Email Configuration (For notifications - Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@liver-ai.com

# File Upload Settings
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads
MODELS_DIR=./models
REPORTS_DIR=./reports

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://yourdomain.com

# AI Model Configuration
ML_MODEL_PATH=models/ml_model.pkl
DL_MODEL_PATH=models/dl_model.h5
FUSION_STRATEGY=dynamic_weight
ML_WEIGHT=0.4
DL_WEIGHT=0.6

# Security
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
SECURE_COOKIES=False  # Set to True in production
HTTPS_ONLY=False      # Set to True in production

# Feature Flags
ENABLE_CHATBOT=True
ENABLE_PDF_EXPORT=True
ENABLE_ANALYTICS=True
